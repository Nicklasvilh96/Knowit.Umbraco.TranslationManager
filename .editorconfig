root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csproj,sln,props,targets,cshtml}]
indent_style = space
indent_size = 4

[*.{json,yml,yaml,md,js,ts,css,html}]
indent_style = space
indent_size = 2

[*.cs]
dotnet_diagnostic.IDE0161.severity = warning
