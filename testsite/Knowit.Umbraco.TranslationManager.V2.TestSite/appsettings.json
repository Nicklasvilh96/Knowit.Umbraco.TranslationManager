{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Umbraco": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": ""
      },
      "ConnectionStrings": {
        "DefaultConnection": ""
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  },
  "TranslationManager": {
    "CacheDurationMinutes": 5,
    "ExcludedDirectories": [
      "node_modules",
      "bin",
      "obj",
      ".git",
      "dist",
      ".vite",
      "wwwroot"
    ],
    "ScanSources": [
      {
        "Name": "React",
        "RootPath": "../frontend/src/components",
        "FilePatterns": [
          "*.tsx",
          "*.ts",
          "*.jsx",
          "*.js"
        ],
        "KeyPattern": "\\bt\\(['\"]([^'\"]+)['\"]\\)"
      },
      {
        "Name": "Razor",
        "RootPath": ".",
        "FilePatterns": [
          "*.cshtml",
          "*.cs"
        ],
        "KeyPattern": "GetDictionaryValue(?:OrDefault)?\\(\\s*\"([^\"]+)\""
      }
    ]
  }
}
